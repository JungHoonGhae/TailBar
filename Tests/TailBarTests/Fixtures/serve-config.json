{
  "TCP": {
    "443": {
      "HTTPS": true
    },
    "8443": {
      "HTTPS": true
    }
  },
  "Web": {
    "my-mac.tail12345.ts.net:443": {
      "Handlers": {
        "/": {
          "Proxy": "http://127.0.0.1:3000"
        }
      }
    },
    "my-mac.tail12345.ts.net:8443": {
      "Handlers": {
        "/": {
          "Proxy": "http://127.0.0.1:8080"
        },
        "/api": {
          "Proxy": "http://127.0.0.1:4000"
        }
      }
    }
  },
  "AllowFunnel": {
    "my-mac.tail12345.ts.net:443": true,
    "my-mac.tail12345.ts.net:8443": false
  }
}
